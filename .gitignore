# ── Credentials / secrets ─────────────────────────────────────────────────
# hosts.yaml often contains passwords or key paths — exclude it from git.
# Commit hosts.yaml.example instead so new users have a template.
hosts.yaml

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Build / distribution ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env

# ── Environment files ─────────────────────────────────────────────────────
.env
.env.*
*.env

# ── Testing / coverage ────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDE / editor ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Misc ──────────────────────────────────────────────────────────────────
*.log
*.tmp
